{
  "name": "paycryptoone/paycrypto-php-client",
  "description": "PHP client preconfigured for paycrypto.one",
  "version": "1.0.1",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "cryptoscan-one/cryptoscan-client-php": "^1.1"
  },
  "autoload-dev": {
    "psr-4": {
      "PayCrypto\\Client\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "PayCryptoOne"
    }
  ],
  "keywords": [
    "paycrypto",
    "cryptoscan",
    "payments",
    "crypto"
  ],
  "autoload": {
    "psr-4": {
      "PayCrypto\\Client\\": "src/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "scripts": {
    "smoke": "php scripts/smoke.php",
    "e2e": "php scripts/e2e.php"
  }
}
